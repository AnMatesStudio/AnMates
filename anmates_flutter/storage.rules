rules_version = '2';
service firebase.storage {
  match /b/{bucket}/o {

    // User profile photos — uploaded by StorageService during onboarding
    // Path: user_photos/{uid}/{filename}
    match /user_photos/{uid}/{file} {
      // Authenticated users can read all profile photos (discovery / home screen)
      allow read: if request.auth != null;
      // Only the owner can write (upload/delete) their own photos
      allow write: if request.auth != null && request.auth.uid == uid;
    }

    // Deny everything else by default
    match /{document=**} {
      allow read, write: if false;
    }
  }
}
